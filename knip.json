{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": [
        "*.{js,ts}"
      ]
    },
    "packages/net": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/redcap-core": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/appwrite": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/auth": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/errors": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/validators": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/openalex-types": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/fetch-one-api-page": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/fetch-openalex": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/validate-openalex": {
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [
        "src/oa/index.ts"
      ]
    },
    "packages/openalex": {
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [
        "src/errors.ts",
        "src/prompt.ts",
        "src/db/index.ts",
        "src/group/helpers.ts"
      ],
      "ignoreDependencies": [
        "@duckdb/node-api",
        "@effect/experimental",
        "@effect/platform-node",
        "@xenova/transformers",
        "uuid"
      ]
    },
    "apps/amarre": {
      "project": [
        "src/**/*.ts",
        "src/**/*.svelte"
      ],
      "ignore": [
        "src/lib/ui/Retrieve.svelte",
        "src/lib/ui/Rule.svelte"
      ],
      "ignoreDependencies": [
        "@univ-lehavre/atlas-logos"
      ]
    },
    "apps/ecrin": {
      "project": [
        "src/**/*.ts",
        "src/**/*.svelte"
      ],
      "ignore": [
        "src/lib/ui/Button.svelte",
        "src/lib/ui/TakeTheSurvey.svelte",
        "src/lib/redcap/index.ts"
      ],
      "ignoreDependencies": [
        "@univ-lehavre/atlas-logos",
        "appwrite",
        "graphology-layout-force",
        "luxon",
        "openapi-response-validator",
        "uuid",
        "@types/luxon"
      ]
    },
    "apps/find-an-expert": {
      "project": [
        "src/**/*.ts",
        "src/**/*.svelte"
      ],
      "ignoreDependencies": [
        "@univ-lehavre/atlas-logos",
        "tailwindcss"
      ]
    },
    "cli/biblio-cli": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/researcher-profiles": {
      "project": [
        "src/**/*.ts"
      ],
      "ignoreDependencies": [
        "@xmldom/xmldom"
      ]
    },
    "cli/researcher-profiles": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "cli/redcap-openapi": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "config/shared-config": {
      "project": [
        "*.json",
        "eslint/**/*.js",
        "prettier/**/*.js"
      ]
    },
    "sandbox/redcap-sandbox": {
      "project": [
        "tests/**/*.ts"
      ]
    },
    "packages/redcap-client": {
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [
        "src/brands.ts",
        "src/errors.ts",
        "src/version.ts"
      ]
    },
    "services/crf": {
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [
        "src/server/schemas.ts"
      ]
    },
    "cli/crf-cli": {
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [
        "src/redcap/commands.ts",
        "src/shared/context.ts",
        "src/shared/terminal.ts"
      ]
    },
    "cli/net-cli": {
      "project": [
        "src/**/*.ts"
      ]
    }
  },
  "ignoreDependencies": [
    "@univ-lehavre/atlas-shared-config",
    "vitepress-openapi",
    "@modyfi/vite-plugin-yaml",
    "simple-git",
    "chart.js",
    "vue-chartjs",
    "mermaid",
    "vitepress-plugin-mermaid",
    "dayjs",
    "debug",
    "cytoscape",
    "cytoscape-cose-bilkent"
  ]
}
