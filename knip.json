{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["*.{js,ts}"],
      "ignoreDependencies": [
        "eslint",
        "prettier-plugin-svelte",
        "@braintree/sanitize-url"
      ]
    },
    "packages/net": {
      "project": ["src/**/*.ts"]
    },
    "packages/crf-core": {
      "project": ["src/**/*.ts"]
    },
    "packages/baas": {
      "project": ["src/**/*.ts"]
    },
    "packages/auth": {
      "project": ["src/**/*.ts"]
    },
    "packages/errors": {
      "project": ["src/**/*.ts"]
    },
    "packages/validators": {
      "project": ["src/**/*.ts"]
    },
    "packages/citation-types": {
      "project": ["src/**/*.ts"]
    },
    "packages/fetch-one-api-page": {
      "project": ["src/**/*.ts"]
    },
    "packages/citation-fetch": {
      "project": ["src/**/*.ts"]
    },
    "packages/citation-validate": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/oa/index.ts"]
    },
    "packages/citation": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@effect/experimental",
        "@effect/platform-node",
        "@xenova/transformers",
        "uuid"
      ]
    },
    "cli/citation": {
      "project": ["src/**/*.ts"]
    },
    "apps/amarre": {
      "project": ["src/**/*.ts", "src/**/*.svelte"]
    },
    "apps/sillage": {
      "project": ["src/**/*.ts", "src/**/*.svelte"]
    },
    "apps/ecrin": {
      "project": ["src/**/*.ts", "src/**/*.svelte"],
      "ignore": [
        "src/lib/ui/Button.svelte",
        "src/lib/ui/TakeTheSurvey.svelte",
        "src/lib/crf/index.ts"
      ],
      "ignoreDependencies": [
        "appwrite",
        "graphology-layout-force",
        "luxon",
        "openapi-response-validator",
        "uuid",
        "@types/luxon"
      ]
    },
    "apps/find-an-expert": {
      "project": ["src/**/*.ts", "src/**/*.svelte"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "cli/biblio": {
      "project": ["src/**/*.ts"]
    },
    "packages/researcher-profiles": {
      "project": ["src/**/*.ts"]
    },
    "cli/researcher-profiles": {
      "project": ["src/**/*.ts"],
      "ignoreBinaries": ["perl", "pandoc"]
    },
    "cli/crf-openapi": {
      "project": ["src/**/*.ts"]
    },
    "config/shared-config": {
      "project": ["eslint/**/*.js", "prettier/**/*.js"]
    },
    "sandbox/crf-sandbox": {
      "project": ["tests/**/*.ts"]
    },
    "sandbox/sillage-sandbox": {
      "project": ["scripts/**/*.ts", "tests/**/*.ts"]
    },
    "packages/crf-client": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/brands.ts", "src/errors.ts", "src/version.ts"]
    },
    "services/crf": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/server/schemas.ts"]
    },
    "cli/crf": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/commands/api/commands.ts"]
    },
    "cli/net": {
      "project": ["src/**/*.ts"]
    },
    "ui/atlas-ui": {
      "project": ["src/**/*.{ts,svelte}", ".storybook/**/*.ts"],
      "ignore": [
        ".storybook/stubs/app-forms.ts",
        ".storybook/stubs/app-paths.ts"
      ]
    }
  },
  "ignoreDependencies": [
    "@univ-lehavre/atlas-shared-config",
    "vitepress-openapi",
    "@modyfi/vite-plugin-yaml",
    "simple-git",
    "chart.js",
    "vue-chartjs",
    "mermaid",
    "vitepress-plugin-mermaid",
    "dayjs",
    "debug",
    "cytoscape",
    "cytoscape-cose-bilkent"
  ]
}
