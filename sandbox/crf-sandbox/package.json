{
  "name": "@univ-lehavre/atlas-crf-sandbox",
  "version": "2.1.0",
  "private": true,
  "description": "CRF (REDCap) testing sandbox - Docker environment and contract tests for validating OpenAPI specs",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "sandbox/crf-sandbox"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "docker:prepare": "./scripts/prepare-crf-source.sh",
    "docker:up": "pnpm docker:prepare && docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:reset": "docker compose -f docker/docker-compose.yml down -v && pnpm docker:prepare && docker compose -f docker/docker-compose.yml up -d",
    "docker:install": "./scripts/install-crf.sh",
    "test:setup": "tsx tests/fixtures/setup-test-projects.ts",
    "test:contract": "./scripts/test-contract.sh",
    "test:contract:amarre": "vitest run --config vitest.contract.config.ts tests/contract-amarre",
    "test:docker": "pnpm docker:reset && pnpm docker:install && pnpm test:setup && pnpm test:contract",
    "test:security": "./scripts/test-security.sh",
    "test:api": "tsx tests/api-smoke.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint tests",
    "lint:fix": "eslint tests --fix",
    "format": "prettier --write tests",
    "format:check": "prettier --check tests"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
