# Example environment for sillage-sandbox (DO NOT put real secrets here)
# Copy to .env and tune. .env is gitignored.

# ─────────────────────────────────────────────────────────────────────
# BaaS (Appwrite self-hosted)
# ─────────────────────────────────────────────────────────────────────
APP_PORT=8090
APP_CONSOLE_PORT=8091
APP_DOMAIN=localhost
APP_DOMAIN_TARGET=localhost
_APP_OPENSSL_KEY_V1=__set_a_random_string_here__
# DB (MongoDB) — Appwrite 1.9 défaut. Pour repasser en MariaDB, set
# _APP_DB_ADAPTER=mariadb dans le compose et ajuster host/port/user.
_APP_DB_HOST=baas-mongodb
_APP_DB_PORT=27017
_APP_DB_USER=root
_APP_DB_PASS=baas_password
_APP_DB_SCHEMA=appwrite
_APP_REDIS_HOST=baas-redis
_APP_REDIS_PORT=6379

# SMTP — pointe vers le service Mailpit du crf-sandbox (catch-all local,
# UI sur http://localhost:8025). Ne pas changer sauf si on remplace Mailpit.
_APP_SMTP_HOST=mailpit
_APP_SMTP_PORT=1025

# Credentials root Appwrite — dev-only, sandbox locale, jamais à exposer.
# Le password DOIT faire ≥ 8 caractères (contrainte Appwrite).
APPWRITE_ROOT_EMAIL=admin@sillage.local
APPWRITE_ROOT_PASSWORD=admin-dev-only-change-me
APPWRITE_ROOT_NAME="Sillage Sandbox Admin"

# Organisation + projet créés par `pnpm bootstrap:baas`. IDs stables pour
# que le script soit idempotent et que le projet soit reconnaissable dans
# la console.
APPWRITE_ORG_ID=org-sillage-sandbox
APPWRITE_ORG_NAME="Sillage Sandbox"
APPWRITE_PROJECT_ID=sillage
APPWRITE_PROJECT_NAME=sillage
APPWRITE_PROJECT_REGION=default

# Sender côté Appwrite (visible dans Mailpit). Forme : "Name <addr>".
APPWRITE_SYSTEM_EMAIL_NAME="Sillage Sandbox"
APPWRITE_SYSTEM_EMAIL_ADDRESS=no-reply@sillage.local

# Persistés par `pnpm bootstrap:baas` après la création du projet/key.
# Laisser tels quels au premier run.
PUBLIC_APPWRITE_ENDPOINT=http://localhost:8090/v1
PUBLIC_APPWRITE_PROJECT=__filled_by_bootstrap__
APPWRITE_KEY=__filled_by_bootstrap__

# ─────────────────────────────────────────────────────────────────────
# CRF (REDCap) — réutilise sandbox/crf-sandbox via `include:`
# ─────────────────────────────────────────────────────────────────────
PUBLIC_CRF_URL=http://localhost:8888/api/

# Persisté par `pnpm bootstrap:crf` (projet dédié sillage dans REDCap).
CRF_API_TOKEN=__filled_by_bootstrap__

# Volume du seed `pnpm seed`. Le script génère N records cohérents
# couvrant les principaux états (incomplet, en cours, validé, refusé).
SEED_RECORD_COUNT=120

# ─────────────────────────────────────────────────────────────────────
# Pull-from-prod (opt-in, manuel — ne JAMAIS commit ces valeurs)
# ─────────────────────────────────────────────────────────────────────
# Pour `pnpm pull:prod`. Renseigne ces deux variables AVEC PRUDENCE :
# elles donnent au script l'accès aux vraies données du projet sillage
# en prod. Les données pull-ées seront écrites dans REDCap local en
# clair sur ta machine.
PROD_CRF_URL=
PROD_CRF_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# sillage app (when run on the host via `pnpm -F sillage dev`)
# ─────────────────────────────────────────────────────────────────────
ALLOWED_DOMAINS_REGEXP="@(example\.org|univ-lehavre\.fr|sillage\.local)"
PUBLIC_LOGIN_URL=http://localhost:5173

# Email utilisé par `pnpm test:e2e` pour exercer le flow magic link.
# Doit matcher ALLOWED_DOMAINS_REGEXP.
E2E_TEST_EMAIL=e2e-tester@sillage.local
