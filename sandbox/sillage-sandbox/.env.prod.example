# Persistent credentials override file — NEVER commit (gitignored).
#
# Copy to `.env.prod` and fill in. The values here are sourced by
# `pnpm start` and `pnpm bootstrap` AFTER `.env` is loaded, so they
# override the empty placeholders without being wiped when `.env`
# gets re-generated.
#
# Used to keep your prod REDCap credentials safe across:
#   - `docker compose down -v` (wipes volumes only, not files)
#   - manual `rm .env` (e.g. when switching branches)
#   - `.env.example` updates

# ─────────────────────────────────────────────────────────────────────
# Main project (ECRIN v2-alpha — contact, researcher_profile,
# research_questions, publications, project_proposal forms).
# ─────────────────────────────────────────────────────────────────────

# PROD_CRF_URL : endpoint API REDCap de prod. DOIT inclure `/api/` final.
# Exemple : https://redcap.univ-lehavre.fr/api/
PROD_CRF_URL=

# Token API du projet sillage (ECRIN v2-alpha) côté prod (32-char hex,
# demande à un admin REDCap si tu ne l'as pas — onglet "API" du projet).
PROD_CRF_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Lookup tables — référencées par les champs `sql` de project_proposal
# (`topic`, `keyword*`, `method*`, `region*`). Chacune est un projet
# REDCap séparé qui stocke juste des paires `(record, value)` ; le
# dict principal pointe dessus via `data-table:<project_id>`. On les
# importe en local pour que les lookups résolvent. Un token par table —
# demande-les à l'admin REDCap si tu ne les as pas.
# ─────────────────────────────────────────────────────────────────────

# data-table:52 — Topics OpenAlex (T-IDs + libellés). Consommée par
# `topic` ainsi que `method1`/`method2`/`method3` (le dict filtre tous
# ces fields sur `field_name = 'topic'` — méthodes incluses).
PROD_CRF_TOPICS_TOKEN=

# data-table:54 — Keywords / concepts OpenAlex. Consommée par
# `keyword1`, `keyword2`, `keyword3`.
PROD_CRF_KEYWORDS_TOKEN=

# data-table:129 — Référentiel régions. Consommé par `region1`,
# `region2`, `region3`.
PROD_CRF_REGIONS_TOKEN=
