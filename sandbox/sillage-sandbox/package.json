{
  "name": "@univ-lehavre/atlas-sillage-sandbox",
  "version": "0.2.0",
  "description": "Local Docker sandbox for the sillage app: bundles a CRF (REDCap) instance, a self-hosted BaaS (Appwrite), and the wiring scripts needed to run sillage end-to-end without depending on production services.",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "sandbox/sillage-sandbox"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "./scripts/start.sh",
    "stop": "docker compose down --volumes --remove-orphans",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down --volumes --remove-orphans",
    "docker:logs": "docker compose logs -f",
    "bootstrap": "./scripts/bootstrap.sh",
    "bootstrap:baas": "tsx scripts/bootstrap-baas.ts",
    "bootstrap:crf": "tsx scripts/bootstrap-crf.ts",
    "seed": "tsx scripts/seed-fake-data.ts",
    "pull:prod": "tsx scripts/pull-from-prod.ts",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint scripts tests --max-warnings 0",
    "lint:fix": "eslint scripts tests --fix"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "playwright": "^1.50.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "eslint": "^10.4.0"
  }
}
