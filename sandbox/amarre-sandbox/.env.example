# Example environment for amarre-sandbox (DO NOT put real secrets here)
# Copy to .env and tune. .env is gitignored.

# ─────────────────────────────────────────────────────────────────────
# BaaS (Appwrite self-hosted)
# ─────────────────────────────────────────────────────────────────────
APP_PORT=8090
APP_DOMAIN=localhost
APP_DOMAIN_TARGET=localhost
_APP_OPENSSL_KEY_V1=__set_a_random_string_here__
_APP_DB_HOST=baas-mariadb
_APP_DB_PORT=3306
_APP_DB_USER=baas
_APP_DB_PASS=baas_password
_APP_DB_SCHEMA=baas
_APP_REDIS_HOST=baas-redis
_APP_REDIS_PORT=6379

# Project / API key seeded by `pnpm bootstrap:baas` (filled at runtime,
# do not pre-set in .env unless you've already provisioned via console)
PUBLIC_APPWRITE_ENDPOINT=http://localhost:8090/v1
PUBLIC_APPWRITE_PROJECT=__filled_by_bootstrap__
APPWRITE_KEY=__filled_by_bootstrap__

# ─────────────────────────────────────────────────────────────────────
# CRF (REDCap) — réutilise sandbox/crf-sandbox via `include:`
# ─────────────────────────────────────────────────────────────────────
PUBLIC_CRF_URL=http://localhost:8888/api/
CRF_API_TOKEN=__filled_by_bootstrap__

# ─────────────────────────────────────────────────────────────────────
# amarre app (when run on the host via `pnpm -F amarre dev`)
# ─────────────────────────────────────────────────────────────────────
ALLOWED_DOMAINS_REGEXP="@(example\.org|univ-lehavre\.fr)"
PUBLIC_LOGIN_URL=http://localhost:5173
