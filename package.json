{
  "name": "atlas",
  "description": "REDCap API monorepo",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "homepage": "https://github.com/univ-lehavre/atlas#readme",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "svelte:check": "turbo check",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "coverage:report": "node scripts/audit/coverage-report.mjs",
    "ci:checks": "turbo run format:check check lint typecheck test:coverage build",
    "audit:security": "pnpm audit --audit-level=high",
    "audit:licenses": "node scripts/audit/licenses.mjs",
    "audit:unused": "knip --exclude unresolved,types",
    "audit:structure": "node scripts/audit/workspace-structure.mjs",
    "audit:duplicates": "jscpd --pattern \"packages/*/src/**/*.ts\" --pattern \"apps/*/src/**/*.ts\" --pattern \"services/*/src/**/*.ts\"",
    "audit:size": "size-limit",
    "audit:versions": "taze -r --ignore-paths cli/crf-openapi/upstream",
    "audit:dep-versions": "node scripts/audit/dep-versions.mjs",
    "ci:audit": "pnpm audit:security && pnpm audit:licenses && pnpm audit:unused && pnpm audit:structure && pnpm audit:duplicates && pnpm audit:size && pnpm audit:dep-versions",
    "stats:generate": "tsx scripts/docs/generate-repo-stats.ts",
    "api:sidebar": "tsx scripts/docs/generate-api-sidebar.ts",
    "docs:dev": "pnpm api:sidebar && vitepress dev docs",
    "docs:build": "pnpm docs:api && pnpm api:sidebar && pnpm stats:generate && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:api": "typedoc",
    "changeset:add": "changeset",
    "changeset:version": "changeset version && pnpm exec prettier --no-config --write '**/CHANGELOG.md'",
    "changeset:publish": "turbo build --filter='!./apps/**' && changeset publish",
    "release": "turbo build --filter='!./apps/**' && ./scripts/release/publish-packages.sh",
    "release:deprecate-renamed": "./scripts/release/deprecate-renamed-packages.sh",
    "crf:dictionaries:export": "tsx scripts/crf-trame/export-data-dictionaries.ts",
    "crf:fixtures:generate": "tsx scripts/crf-trame/generate-test-fixtures.ts",
    "others": "git -C . ls-files --others | grep -v -e 'node_modules' -e '.svelte-kit' ",
    "clean": "pnpm dlx rimraf --glob '**/node_modules' '**/dist' '**/build' '**/.svelte-kit' '**/.turbo' '**/coverage' '**/*.traineddata' '**/.hypothesis' 'docs/.vitepress/cache' 'docs/api' '**/upstream/versions' '**/.DS_Store' 'docs/.vitepress/data/repo-stats.json' 'apps/*/tests/baselines/*.json' 'docs/.vitepress/dist' 'docs/.vitepress/.temp' 'docs/.vitepress/vite-ssg-*.json'",
    "prepare": "lefthook install"
  },
  "size-limit": [
    {
      "path": "packages/net/dist/**/*.js",
      "limit": "20 KB"
    },
    {
      "path": "services/crf/dist/**/*.js",
      "limit": "100 KB"
    },
    {
      "path": "packages/citation-fetch/dist/**/*.js",
      "limit": "140 KB"
    },
    {
      "path": "packages/researcher-profiles/dist/**/*.js",
      "limit": "230 KB"
    },
    {
      "path": "packages/citation/dist/**/*.js",
      "limit": "250 KB"
    },
    {
      "path": "packages/crf-client/dist/**/*.js",
      "limit": "260 KB"
    },
    {
      "path": "packages/citation-validate/dist/**/*.js",
      "limit": "700 KB"
    },
    {
      "path": "packages/crf-core/dist/**/*.js",
      "limit": "750 KB"
    }
  ],
  "jscpd": {
    "threshold": 5,
    "reporters": [
      "console"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/*.d.ts"
    ],
    "format": [
      "typescript"
    ],
    "minLines": 10,
    "minTokens": 50
  },
  "typedocOptions": {
    "entryPoints": [
      "packages/crf-client",
      "packages/net",
      "packages/crf-core",
      "packages/errors",
      "packages/validators",
      "packages/baas",
      "packages/auth",
      "packages/citation-types",
      "packages/fetch-one-api-page",
      "packages/citation-fetch",
      "packages/citation-validate",
      "packages/citation",
      "services/crf",
      "cli/crf-openapi",
      "cli/biblio",
      "packages/researcher-profiles",
      "cli/crf",
      "cli/net",
      "cli/researcher-profiles"
    ],
    "entryPointStrategy": "packages",
    "out": "docs/api",
    "plugin": [
      "typedoc-plugin-markdown"
    ],
    "readme": "none",
    "excludePrivate": true,
    "excludeInternal": true,
    "excludeExternals": true,
    "entryFileName": "index",
    "indexFormat": "table",
    "hidePageHeader": true,
    "hideBreadcrumbs": true
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@size-limit/file": "^12.1.0",
    "@univ-lehavre/atlas-crf-client": "workspace:*",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "effect": "^3.21.2",
    "@vitest/coverage-v8": "^4.1.6",
    "chart.js": "^4.5.1",
    "cytoscape": "^3.33.3",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.20",
    "debug": "^4.4.3",
    "jscpd": "^4.0.9",
    "knip": "^6.14.1",
    "lefthook": "^2.1.6",
    "mermaid": "^11.15.0",
    "prettier": "^3.8.3",
    "simple-git": "^3.36.0",
    "size-limit": "^12.1.0",
    "taze": "^19.12.0",
    "tsx": "^4.22.2",
    "turbo": "^2.9.14",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitepress": "^1.6.4",
    "vitepress-openapi": "^0.1.20",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.6",
    "vue-chartjs": "^5.3.3"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "@sveltejs/kit": ">=2.58.0",
      "@xmldom/xmldom": ">=0.9.10",
      "defu": ">=6.1.7",
      "devalue": ">=5.8.1",
      "effect": ">=3.21.2",
      "fast-uri": ">=3.1.2",
      "fast-xml-parser": ">=5.7.2",
      "flatted": ">=3.4.2",
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1",
      "minimatch": ">=10.2.5",
      "picomatch": ">=4.0.4",
      "protobufjs": ">=8.0.3",
      "rollup": ">=4.60.2",
      "undici": ">=7.25.0 <8"
    },
    "patchedDependencies": {
      "reprism@0.0.11": "patches/reprism@0.0.11.patch"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@effect/vitest>vitest": "^4",
        "@standard-community/standard-json>quansync": "^1",
        "openapi-typescript>typescript": "^6"
      }
    }
  }
}
