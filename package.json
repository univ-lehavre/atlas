{
  "name": "atlas",
  "description": "REDCap API monorepo",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "homepage": "https://github.com/univ-lehavre/atlas#readme",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "svelte:check": "turbo check",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "coverage:report": "node scripts/audit/coverage-report.mjs",
    "coverage:report:strict": "node scripts/audit/coverage-report.mjs --strict",
    "test:scripts": "node --test scripts/audit/*.test.mjs",
    "ci:checks": "turbo run format:check check lint typecheck test:coverage build",
    "audit:security": "pnpm audit --audit-level=moderate",
    "audit:licenses": "node scripts/audit/licenses.mjs",
    "audit:unused": "knip --exclude unresolved,types",
    "audit:structure": "node scripts/audit/workspace-structure.mjs",
    "audit:duplicates": "jscpd --pattern \"packages/*/src/**/*.ts\" --pattern \"apps/*/src/**/*.ts\" --pattern \"services/*/src/**/*.ts\"",
    "audit:size": "size-limit",
    "audit:versions": "taze -r --ignore-paths cli/crf-openapi/upstream",
    "audit:dep-versions": "node scripts/audit/dep-versions.mjs",
    "ci:audit": "pnpm audit:security && pnpm audit:licenses && pnpm audit:unused && pnpm audit:structure && pnpm audit:duplicates && pnpm audit:size && pnpm audit:dep-versions",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset:add": "changeset",
    "changeset:version": "changeset version && pnpm exec prettier --write '**/CHANGELOG.md'",
    "changeset:publish": "turbo build --filter='!./apps/**' && changeset publish",
    "release": "turbo build --filter='!./apps/**' && ./scripts/release/publish-packages.sh",
    "release:deprecate-renamed": "./scripts/release/deprecate-renamed-packages.sh",
    "crf:dictionaries:export": "tsx scripts/crf-trame/export-data-dictionaries.ts",
    "crf:fixtures:generate": "tsx scripts/crf-trame/generate-test-fixtures.ts",
    "others": "git -C . ls-files --others | grep -v -e 'node_modules' -e '.svelte-kit' ",
    "clean": "pnpm dlx rimraf --glob '**/node_modules' '**/dist' '**/build' '**/.svelte-kit' '**/.turbo' '**/coverage' '**/*.traineddata' '**/.hypothesis' 'docs/.vitepress/cache' 'docs/api' '**/upstream/versions' '**/.DS_Store' 'docs/.vitepress/data/repo-stats.json' 'docs/.vitepress/dist' 'docs/.vitepress/.temp' 'docs/.vitepress/vite-ssg-*.json'",
    "prepare": "lefthook install"
  },
  "size-limit": [
    {
      "path": "packages/net/dist/**/*.js",
      "limit": "20 KB"
    },
    {
      "path": "services/crf/dist/**/*.js",
      "limit": "100 KB"
    },
    {
      "path": "packages/citation-fetch/dist/**/*.js",
      "limit": "140 KB"
    },
    {
      "path": "packages/researcher-profiles/dist/**/*.js",
      "limit": "230 KB"
    },
    {
      "path": "packages/citation/dist/**/*.js",
      "limit": "250 KB"
    },
    {
      "path": "packages/crf-client/dist/**/*.js",
      "limit": "260 KB"
    },
    {
      "path": "packages/citation-validate/dist/**/*.js",
      "limit": "700 KB"
    },
    {
      "path": "packages/crf-core/dist/**/*.js",
      "limit": "750 KB"
    }
  ],
  "jscpd": {
    "threshold": 5,
    "reporters": [
      "console"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/*.d.ts"
    ],
    "format": [
      "typescript"
    ],
    "minLines": 10,
    "minTokens": 50
  },
  "typedocOptions": {
    "entryPoints": [
      "packages/crf-client",
      "packages/net",
      "packages/crf-core",
      "packages/errors",
      "packages/validators",
      "packages/baas",
      "packages/auth",
      "packages/citation-types",
      "packages/fetch-one-api-page",
      "packages/citation-fetch",
      "packages/citation-validate",
      "packages/citation",
      "services/crf",
      "cli/crf-openapi",
      "cli/biblio",
      "packages/researcher-profiles",
      "cli/crf",
      "cli/net",
      "cli/researcher-profiles"
    ],
    "entryPointStrategy": "packages",
    "out": "docs/api",
    "plugin": [
      "typedoc-plugin-markdown"
    ],
    "readme": "none",
    "excludePrivate": true,
    "excludeInternal": true,
    "excludeExternals": true,
    "entryFileName": "index",
    "indexFormat": "table",
    "hidePageHeader": true,
    "hideBreadcrumbs": true
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@size-limit/file": "^12.1.0",
    "@univ-lehavre/atlas-crf-client": "workspace:*",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "effect": "^3.21.2",
    "@vitest/coverage-v8": "^4.1.7",
    "chart.js": "^4.5.1",
    "cytoscape": "^3.33.4",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.20",
    "debug": "^4.4.3",
    "eslint": "^10.4.0",
    "jscpd": "^4.0.9",
    "knip": "^6.14.2",
    "lefthook": "^2.1.8",
    "mermaid": "^11.15.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "simple-git": "^3.36.0",
    "size-limit": "^12.1.0",
    "taze": "^19.14.1",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitepress": "^1.6.4",
    "vitepress-openapi": "^0.2.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.7",
    "vue-chartjs": "^5.3.3"
  },
  "packageManager": "pnpm@10.33.2"
}
