{
  "name": "atlas",
  "description": "Generalist monorepo bundling several software projects under a shared quality pipeline",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "homepage": "https://github.com/univ-lehavre/atlas#readme",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "svelte:check": "turbo check",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "coverage:report": "node scripts/audit/coverage-report.mjs",
    "coverage:report:strict": "node scripts/audit/coverage-report.mjs --strict",
    "test:scripts": "node --test scripts/audit/*.test.mjs scripts/docs/*.test.mjs scripts/drifts/*.test.mjs",
    "ci:checks": "turbo run format:check check lint typecheck test:coverage build && pnpm dataops:check",
    "lint:python": "turbo run lint:py --filter='./dataops/*'",
    "test:python": "turbo run test:py --filter='./dataops/*'",
    "dataops:manifests": "turbo run manifests:py --filter='./dataops/*'",
    "dataops:check": "turbo run lint:py test:py manifests:py --filter='./dataops/*'",
    "audit:security": "pnpm audit --audit-level=moderate",
    "audit:licenses": "node scripts/audit/licenses.mjs",
    "audit:unused": "knip --exclude unresolved,types",
    "audit:phantom-peers": "node scripts/audit/phantom-peers.mjs",
    "audit:structure": "node scripts/audit/workspace-structure.mjs",
    "audit:duplicates": "jscpd --pattern \"packages/*/src/**/*.ts\" --pattern \"apps/*/src/**/*.ts\" --pattern \"services/*/src/**/*.ts\"",
    "audit:size": "size-limit",
    "audit:versions": "taze -r --ignore-paths cli/crf-openapi/upstream",
    "audit:dep-versions": "node scripts/audit/dep-versions.mjs",
    "audit:docs": "node scripts/audit/documentation.mjs",
    "ci:audit": "pnpm audit:security && pnpm audit:licenses && pnpm audit:unused && pnpm audit:phantom-peers && pnpm audit:structure && pnpm audit:duplicates && pnpm audit:size && pnpm audit:dep-versions && pnpm docs:generate:check && pnpm audit:docs",
    "docs:generate": "node scripts/docs/generate-packages-map.mjs",
    "docs:generate:check": "node scripts/docs/generate-packages-map.mjs --check",
    "stats:generate": "tsx scripts/docs/generate-repo-stats.ts",
    "docs:prepare": "pnpm stats:generate && pnpm docs:generate",
    "docs:dev": "pnpm docs:prepare && pnpm --filter @univ-lehavre/atlas-docs docs:dev",
    "docs:build": "pnpm docs:prepare && pnpm --filter @univ-lehavre/atlas-docs docs:build",
    "docs:preview": "pnpm --filter @univ-lehavre/atlas-docs docs:preview",
    "changeset:add": "changeset",
    "changeset:version": "changeset version && pnpm exec prettier --write '**/CHANGELOG.md'",
    "changeset:publish": "turbo build --filter='!./apps/**' && changeset publish",
    "release": "turbo build --filter='!./apps/**' && ./scripts/release/publish-packages.sh",
    "release:deprecate-renamed": "./scripts/release/deprecate-renamed-packages.sh",
    "crf:dictionaries:export": "tsx scripts/crf-trame/export-data-dictionaries.ts",
    "crf:fixtures:generate": "tsx scripts/crf-trame/generate-test-fixtures.ts",
    "drift:new": "node scripts/drifts/promote-draft.mjs",
    "others": "git -C . ls-files --others | grep -v -e 'node_modules' -e '.svelte-kit' ",
    "clean": "pnpm dlx rimraf --glob '**/node_modules' '**/dist' '**/build' '**/.svelte-kit' '**/.turbo' '**/coverage' '**/*.traineddata' '**/.hypothesis' 'docs/api' 'docs/.astro' 'docs/src/data/repo-stats.json' '**/upstream/versions' '**/.DS_Store'",
    "prepare": "command -v git >/dev/null 2>&1 && git rev-parse --git-dir >/dev/null 2>&1 && lefthook install || true"
  },
  "size-limit": [
    {
      "name": "atlas-stats",
      "path": [
        "packages/atlas-stats/dist/**/*.js",
        "!packages/atlas-stats/dist/**/*.test.js",
        "!packages/atlas-stats/dist/**/*.spec.js"
      ],
      "limit": "12 KB"
    },
    {
      "name": "auth",
      "path": [
        "packages/auth/dist/**/*.js",
        "!packages/auth/dist/**/*.test.js",
        "!packages/auth/dist/**/*.spec.js"
      ],
      "limit": "6 KB"
    },
    {
      "name": "baas",
      "path": [
        "packages/baas/dist/**/*.js",
        "!packages/baas/dist/**/*.test.js",
        "!packages/baas/dist/**/*.spec.js"
      ],
      "limit": "2 KB"
    },
    {
      "name": "citation",
      "path": [
        "packages/citation/dist/**/*.js",
        "!packages/citation/dist/**/*.test.js",
        "!packages/citation/dist/**/*.spec.js"
      ],
      "limit": "14 KB"
    },
    {
      "name": "citation-fetch",
      "path": [
        "packages/citation-fetch/dist/**/*.js",
        "!packages/citation-fetch/dist/**/*.test.js",
        "!packages/citation-fetch/dist/**/*.spec.js"
      ],
      "limit": "9 KB"
    },
    {
      "name": "citation-types",
      "path": [
        "packages/citation-types/dist/**/*.js",
        "!packages/citation-types/dist/**/*.test.js",
        "!packages/citation-types/dist/**/*.spec.js"
      ],
      "limit": "2 KB"
    },
    {
      "name": "citation-validate",
      "path": [
        "packages/citation-validate/dist/**/*.js",
        "!packages/citation-validate/dist/**/*.test.js",
        "!packages/citation-validate/dist/**/*.spec.js"
      ],
      "limit": "28 KB"
    },
    {
      "name": "crf-client",
      "path": [
        "packages/crf-client/dist/**/*.js",
        "!packages/crf-client/dist/**/*.test.js",
        "!packages/crf-client/dist/**/*.spec.js"
      ],
      "limit": "14 KB"
    },
    {
      "name": "crf-core",
      "path": [
        "packages/crf-core/dist/**/*.js",
        "!packages/crf-core/dist/**/*.test.js",
        "!packages/crf-core/dist/**/*.spec.js"
      ],
      "limit": "28 KB"
    },
    {
      "name": "crf-logs",
      "path": [
        "packages/crf-logs/dist/**/*.js",
        "!packages/crf-logs/dist/**/*.test.js",
        "!packages/crf-logs/dist/**/*.spec.js"
      ],
      "limit": "9 KB"
    },
    {
      "name": "errors",
      "path": [
        "packages/errors/dist/**/*.js",
        "!packages/errors/dist/**/*.test.js",
        "!packages/errors/dist/**/*.spec.js"
      ],
      "limit": "3 KB"
    },
    {
      "name": "fetch-one-api-page",
      "path": [
        "packages/fetch-one-api-page/dist/**/*.js",
        "!packages/fetch-one-api-page/dist/**/*.test.js",
        "!packages/fetch-one-api-page/dist/**/*.spec.js"
      ],
      "limit": "3 KB"
    },
    {
      "name": "net",
      "path": [
        "packages/net/dist/**/*.js",
        "!packages/net/dist/**/*.test.js",
        "!packages/net/dist/**/*.spec.js"
      ],
      "limit": "9 KB"
    },
    {
      "name": "researcher-profiles",
      "path": [
        "packages/researcher-profiles/dist/**/*.js",
        "!packages/researcher-profiles/dist/**/*.test.js",
        "!packages/researcher-profiles/dist/**/*.spec.js"
      ],
      "limit": "24 KB"
    },
    {
      "name": "sveltekit-csp",
      "path": [
        "packages/sveltekit-csp/dist/**/*.js",
        "!packages/sveltekit-csp/dist/**/*.test.js",
        "!packages/sveltekit-csp/dist/**/*.spec.js"
      ],
      "limit": "3 KB"
    },
    {
      "name": "sveltekit-handler",
      "path": [
        "packages/sveltekit-handler/dist/**/*.js",
        "!packages/sveltekit-handler/dist/**/*.test.js",
        "!packages/sveltekit-handler/dist/**/*.spec.js"
      ],
      "limit": "2 KB"
    },
    {
      "name": "validators",
      "path": [
        "packages/validators/dist/**/*.js",
        "!packages/validators/dist/**/*.test.js",
        "!packages/validators/dist/**/*.spec.js"
      ],
      "limit": "2 KB"
    },
    {
      "name": "crf-project-template",
      "path": [
        "packages/crf-project-template/dist/**/*.js",
        "!packages/crf-project-template/dist/**/*.test.js",
        "!packages/crf-project-template/dist/**/*.spec.js"
      ],
      "limit": "3 KB"
    },
    {
      "name": "crf-fixtures",
      "path": [
        "packages/crf-fixtures/dist/**/*.js",
        "!packages/crf-fixtures/dist/**/*.test.js",
        "!packages/crf-fixtures/dist/**/*.spec.js"
      ],
      "limit": "5 KB"
    },
    {
      "name": "cli-toolkit",
      "path": [
        "packages/cli-toolkit/dist/**/*.js",
        "!packages/cli-toolkit/dist/**/*.test.js",
        "!packages/cli-toolkit/dist/**/*.spec.js"
      ],
      "limit": "2 KB"
    },
    {
      "name": "services-crf",
      "path": [
        "services/crf/dist/**/*.js",
        "!services/crf/dist/**/*.test.js"
      ],
      "limit": "60 KB"
    }
  ],
  "jscpd": {
    "threshold": 5,
    "reporters": [
      "console"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/*.d.ts"
    ],
    "format": [
      "typescript"
    ],
    "minLines": 10,
    "minTokens": 50
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@size-limit/file": "^12.1.0",
    "@univ-lehavre/atlas-crf-client": "workspace:*",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.9",
    "debug": "^4.4.3",
    "effect": "^3.21.4",
    "eslint": "^10.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.1",
    "prettier-plugin-svelte": "^3.5.2",
    "simple-git": "^3.36.0",
    "size-limit": "^12.1.0",
    "taze": "^19.14.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.2"
}
