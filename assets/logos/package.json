{
  "name": "@univ-lehavre/atlas-logos",
  "version": "2.0.0",
  "description": "Logos and brand assets for Atlas projects",
  "type": "module",
  "exports": {
    "./*": "./*",
    "./package.json": "./package.json"
  },
  "files": [
    "*.png",
    "*.svg",
    "*.jpg"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
