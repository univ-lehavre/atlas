{
  "name": "@univ-lehavre/atlas-redcap-client",
  "version": "2.0.0",
  "description": "REDCap API client for Atlas - Effect-based typed client",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/redcap-client"
  },
  "keywords": [
    "redcap",
    "api-client",
    "effect",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "specs"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "generate:types": "openapi-typescript specs/versions/redcap-${REDCAP_VERSION:-14.5.10}.yaml -o src/generated/types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@univ-lehavre/atlas-net": "workspace:*",
    "@univ-lehavre/atlas-redcap-core": "workspace:*",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^9.39.2",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
