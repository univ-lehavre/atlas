{
  "name": "@univ-lehavre/atlas-openalex",
  "version": "1.0.3",
  "description": "OpenAlex data mining library with DuckDB, ML embeddings, and string grouping",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/openalex"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@duckdb/node-api": "1.3.4-alpha.27",
    "@effect/experimental": "^0.60.0",
    "@effect/platform-node": "^0.106.0",
    "@univ-lehavre/atlas-fetch-one-api-page": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "effect": "^3.21.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
