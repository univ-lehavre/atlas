{
  "name": "@univ-lehavre/atlas-openalex",
  "version": "1.0.1",
  "description": "OpenAlex data mining CLI with DuckDB, ML embeddings, and string grouping",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/openalex"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node --env-file ../../.env dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0-alpha.4",
    "@duckdb/node-api": "1.3.4-alpha.27",
    "@effect/cluster": "^0.58.0",
    "@effect/experimental": "^0.60.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "^0.75.0",
    "@effect/sql": "^0.51.0",
    "@effect/workflow": "^0.18.0",
    "@univ-lehavre/atlas-fetch-one-api-page": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "effect": "^3.21.0",
    "lodash": "^4.17.23",
    "picocolors": "^1.1.1",
    "uuid": "^13.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "@types/yargs": "^17.0.35",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.1.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
