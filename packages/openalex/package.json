{
  "name": "@univ-lehavre/atlas-openalex",
  "version": "1.0.0",
  "description": "OpenAlex data mining CLI with DuckDB, ML embeddings, and string grouping",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/openalex"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node --env-file ../../.env dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0-alpha.4",
    "@duckdb/node-api": "1.3.4-alpha.27",
    "@effect/experimental": "^0.60.0",
    "@effect/platform-node": "^0.104.1",
    "@univ-lehavre/atlas-fetch-one-api-page": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "effect": "^3.19.15",
    "lodash": "^4.17.21",
    "picocolors": "^1.1.1",
    "uuid": "^13.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.20",
    "@types/node": "^25.0.10",
    "@types/yargs": "^17.0.33",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
