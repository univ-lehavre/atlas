{
  "name": "@univ-lehavre/atlas-crf-client",
  "version": "3.0.2",
  "description": "Complex reporting form (CRF) API client for Atlas - Effect-based typed client",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/crf-client"
  },
  "keywords": [
    "redcap",
    "api-client",
    "effect",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "specs"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "generate:types": "openapi-typescript specs/versions/redcap-${REDCAP_VERSION:-14.5.10}.yaml -o src/generated/types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@univ-lehavre/atlas-net": "workspace:*",
    "@univ-lehavre/atlas-crf-core": "workspace:*",
    "effect": "~3.21.4"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/node": "^25.9.3",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.6.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
