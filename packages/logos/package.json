{
  "name": "@univ-lehavre/atlas-logos",
  "version": "1.1.3",
  "description": "Logos and brand assets for Atlas projects",
  "type": "module",
  "exports": {
    "./*": "./*"
  },
  "bin": {
    "atlas-logos-install": "./bin/install.mjs"
  },
  "files": [
    "*.png",
    "*.svg",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "vitest": "^4.1.6"
  }
}
