{
  "name": "@univ-lehavre/atlas-researcher-profiles",
  "version": "2.0.2",
  "description": "Researcher profiles service layer: REDCap/CSV ingestion, OpenAlex matching, PDF/reference extraction",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/researcher-profiles"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@napi-rs/canvas": "~1.0.2",
    "@univ-lehavre/atlas-citation-fetch": "workspace:*",
    "@univ-lehavre/atlas-citation-types": "workspace:*",
    "@univ-lehavre/atlas-crf-client": "workspace:*",
    "@xenova/transformers": "~2.17.2",
    "@xmldom/xmldom": ">=0.9.10",
    "csv-parse": "~7.0.1",
    "effect": "~3.21.4",
    "fuse.js": "~7.4.2",
    "mammoth": "~1.12.0",
    "pdf-lib": "~1.17.1",
    "pdfjs-dist": "~5.7.284",
    "pdfkit": "~0.19.1",
    "tesseract.js": "~7.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/node": "^25.9.3",
    "@types/pdfkit": "^0.17.6",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
