{
  "name": "@univ-lehavre/atlas-researcher-profiles",
  "version": "1.4.0",
  "description": "Researcher profiles service layer: REDCap/CSV ingestion, OpenAlex matching, PDF/reference extraction",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/researcher-profiles"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@univ-lehavre/atlas-fetch-openalex": "workspace:*",
    "@univ-lehavre/atlas-openalex-types": "workspace:*",
    "@univ-lehavre/atlas-redcap-client": "workspace:*",
    "csv-parse": "^5.6.0",
    "effect": "^3.21.0",
    "fuse.js": "^7.1.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "pdfkit": "^0.15.2",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "0.26.0",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.13.9",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
