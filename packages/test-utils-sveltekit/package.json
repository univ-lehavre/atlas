{
  "name": "@univ-lehavre/atlas-test-utils-sveltekit",
  "version": "0.1.0",
  "description": "Shared SvelteKit endpoint test helpers (route-event builder, anti-XSS assertion) for the atlas monorepo.",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/test-utils-sveltekit"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore ."
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.68.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.6.0",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
