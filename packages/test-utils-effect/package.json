{
  "name": "@univ-lehavre/atlas-test-utils-effect",
  "version": "0.1.0",
  "description": "Shared Effect test helpers (test layer providers, in-memory doubles) for the atlas monorepo. Consumed only by other packages' tests; never built or published.",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/test-utils-effect"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore ."
  },
  "dependencies": {
    "@univ-lehavre/atlas-effect-socle": "workspace:*"
  },
  "peerDependencies": {
    "effect": "~3.21.3"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "effect": "~3.21.3",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
