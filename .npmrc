engine-strict=true
# Registry auth (NPM_TOKEN, NODE_AUTH_TOKEN) is injected at release time
# by .github/workflows/release.yml — keeping the lines out of here means
# local dev and other workflows don't trip on the pnpm "Failed to replace
# env in config" WARN.

# Hoist @storybook/* to root node_modules so the storybook CLI can resolve
# sibling framework packages (svelte-vite, react-vite, etc.) from its own
# .pnpm location. pnpm's default symlink layout breaks the resolution.
public-hoist-pattern[]=@storybook/*
