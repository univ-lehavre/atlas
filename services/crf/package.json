{
  "name": "@univ-lehavre/atlas-crf",
  "version": "2.0.0",
  "description": "CRF Service - HTTP microservice for REDCap",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "services/crf"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "homepage": "https://github.com/univ-lehavre/atlas/tree/main/packages/crf#readme",
  "keywords": [
    "redcap",
    "clinical-research",
    "api-client",
    "effect",
    "typescript",
    "hono"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=.env dist/server/index.js",
    "start:dev": "node --env-file=.env --import=tsx src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "./scripts/test-integration.sh",
    "test:api": "./scripts/test-api.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/standard-validator": "^0.2.2",
    "@univ-lehavre/atlas-redcap-client": "workspace:*",
    "effect": "^3.21.0",
    "hono": "^4.12.9",
    "hono-openapi": "^1.3.0",
    "hono-rate-limiter": "^0.5.3"
  },
  "devDependencies": {
    "@scalar/hono-api-reference": "^0.9.37",
    "@types/node": "^25.0.10",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
