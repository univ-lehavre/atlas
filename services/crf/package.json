{
  "name": "@univ-lehavre/atlas-crf",
  "version": "3.1.0",
  "description": "CRF Service - HTTP microservice for complex reporting forms",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "services/crf"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "homepage": "https://github.com/univ-lehavre/atlas/tree/main/packages/crf#readme",
  "keywords": [
    "redcap",
    "complex-forms",
    "api-client",
    "effect",
    "typescript",
    "hono"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=.env dist/server/index.js",
    "start:dev": "node --env-file=.env --import=tsx src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "./scripts/test-integration.sh",
    "test:api": "./scripts/test-api.sh"
  },
  "dependencies": {
    "@effect/opentelemetry": "~0.63.0",
    "@hono/node-server": "~2.0.8",
    "@hono/otel": "~1.1.2",
    "@hono/standard-validator": "~0.2.3",
    "@opentelemetry/api": "~1.9.1",
    "@opentelemetry/exporter-prometheus": "~0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "~0.220.0",
    "@opentelemetry/resources": "~2.9.0",
    "@opentelemetry/sdk-metrics": "~2.9.0",
    "@opentelemetry/sdk-node": "~0.220.0",
    "@opentelemetry/sdk-trace-base": "~2.9.0",
    "@opentelemetry/semantic-conventions": "~1.41.1",
    "@scalar/hono-api-reference": "~0.11.8",
    "@univ-lehavre/atlas-crf-client": "workspace:*",
    "@univ-lehavre/atlas-crf-core": "workspace:*",
    "@univ-lehavre/atlas-effect-socle": "workspace:*",
    "effect": "~3.21.4",
    "hono": "~4.12.27",
    "hono-openapi": "~1.3.1",
    "hono-rate-limiter": "~0.5.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
