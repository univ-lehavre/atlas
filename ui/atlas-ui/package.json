{
  "name": "@univ-lehavre/atlas-ui",
  "version": "0.1.0",
  "description": "Shared Svelte UI components for the atlas monorepo, previewed via Storybook.",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "src/lib",
    "!src/lib/**/*.stories.*"
  ],
  "svelte": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./client": {
      "types": "./src/lib/client.ts",
      "default": "./src/lib/client.ts"
    },
    "./*.svelte": {
      "types": "./src/lib/*.svelte",
      "svelte": "./src/lib/*.svelte",
      "default": "./src/lib/*.svelte"
    }
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore ."
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/svelte-vite": "^10.4.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "storybook": "^10.4.0",
    "svelte": "^5.55.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@univ-lehavre/atlas-validators": "workspace:*",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "luxon": "^3.5.0"
  }
}
