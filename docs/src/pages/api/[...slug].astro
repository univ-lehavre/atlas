---
import { getCollection, render } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

// Référence API : rend chaque fichier markdown généré par TypeDoc en page
// Starlight (collection `api`, ADR 0036). Contenu généré, en anglais, niveau
// expert — équivalent de la section « Référence API » de VitePress.
export async function getStaticPaths() {
  const pages = await getCollection("api");
  return pages.map((entry) => {
    // id slugifié : "index" → racine /api ; "@univ-lehavre/atlas-auth/index"
    // → "@univ-lehavre/atlas-auth".
    const slug = entry.id.replace(/\/index$/i, "").replace(/^index$/i, "");
    return { params: { slug: slug || undefined }, props: { entry, slug } };
  });
}

const { entry, slug } = Astro.props;
const { Content } = await render(entry);

const h1 = entry.body?.match(/^#\s+(.+)$/m);
const title = h1 ? h1[1] : slug || "Référence API";
---

<StarlightPage frontmatter={{ title }}>
  <Content />
</StarlightPage>
