{
  "name": "@univ-lehavre/atlas-shared-config",
  "version": "0.3.1",
  "description": "Shared TypeScript, ESLint, and Prettier configuration for Atlas projects",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "config/shared-config"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "homepage": "https://github.com/univ-lehavre/atlas/tree/main/config/shared-config#readme",
  "keywords": [
    "typescript",
    "tsconfig",
    "eslint",
    "prettier",
    "shared-config"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "*.json",
    "eslint/**/*.js",
    "prettier/**/*.js"
  ],
  "exports": {
    "./base.json": "./base.json",
    "./node.json": "./node.json",
    "./eslint": "./eslint/index.js",
    "./eslint/typescript": "./eslint/typescript.js",
    "./eslint/svelte": "./eslint/svelte.js",
    "./eslint/svelte-relaxed": "./eslint/svelte-relaxed.js",
    "./eslint/scripts": "./eslint/scripts.js",
    "./prettier": "./prettier/index.js",
    "./prettier/base": "./prettier/base.js",
    "./prettier/svelte": "./prettier/svelte.js"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.14",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-barrel-files": "^3.0.1",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-svelte": "^3.16.0",
    "eslint-plugin-turbo": "^2.9.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
