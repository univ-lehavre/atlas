{
  "name": "@univ-lehavre/atlas-researcher-profiles-cli",
  "version": "1.3.2",
  "description": "Researcher profiles CLI: fetch OpenAlex works from CSV or REDCap and write to REDCap",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "tools/cli/researcher-profiles"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "atlas-researcher-profiles": "./dist/bin/atlas-researcher-profiles.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "tsc && node --env-file=../../../.env dist/bin/atlas-researcher-profiles.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@univ-lehavre/atlas-fetch-openalex": "workspace:*",
    "@univ-lehavre/atlas-openalex-types": "workspace:*",
    "@univ-lehavre/atlas-researcher-profiles": "workspace:*",
    "effect": "^3.21.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
