{
  "name": "@univ-lehavre/atlas-biblio-cli",
  "version": "0.2.1",
  "description": "CLI entry point for OpenAlex bibliographic data validation",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "packages/biblio-cli"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "atlas-biblio": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0-alpha.6",
    "@effect/experimental": "^0.60.0",
    "@effect/platform-node": "^0.104.1",
    "@univ-lehavre/atlas-openalex-types": "workspace:*",
    "@univ-lehavre/atlas-validate-openalex": "workspace:*",
    "effect": "^3.19.15"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
