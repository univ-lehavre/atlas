{
  "name": "@univ-lehavre/atlas-redcap-stats-cli",
  "version": "0.2.0",
  "description": "CLI to test REDCap project tokens and inspect API responses",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "tools/cli-redcap-stats"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "atlas-redcap-stats": "./dist/bin/atlas-redcap-stats.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/atlas-redcap-stats.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@univ-lehavre/atlas-redcap-logs": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
