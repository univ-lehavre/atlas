{
  "name": "@univ-lehavre/atlas-crf-cli",
  "version": "3.0.2",
  "description": "CRF CLI - REDCap connectivity test and CRF server management",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "cli/crf"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "crf-redcap": "./dist/bin/crf-api.js",
    "crf-server": "./dist/bin/crf-server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@effect/cli": "^0.75.1",
    "@effect/cluster": "^0.58.2",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@hono/node-server": "^2.0.4",
    "@univ-lehavre/atlas-crf": "workspace:*",
    "@univ-lehavre/atlas-crf-client": "workspace:*",
    "effect": "^3.21.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
