{
  "name": "@univ-lehavre/atlas-net-cli",
  "version": "1.0.8",
  "description": "Network diagnostic CLI for Atlas",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "cli/net"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "atlas-net": "./dist/bin/atlas-net.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/atlas-net.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "~1.6.0",
    "@effect/cli": "~0.75.2",
    "@effect/platform": "~0.96.2",
    "@effect/printer": "~0.49.0",
    "@effect/printer-ansi": "~0.49.0",
    "@univ-lehavre/atlas-cli-toolkit": "workspace:*",
    "@univ-lehavre/atlas-net": "workspace:*",
    "effect": "~3.21.4",
    "picocolors": "~1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
