{
  "name": "@univ-lehavre/atlas-citation-cli",
  "version": "2.0.0",
  "description": "CLI for OpenAlex citation graph researcher data curation",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "cli/citation"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "atlas-citation": "./dist/bin/atlas-citation.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node --env-file ../../.env dist/bin/atlas-citation.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@univ-lehavre/atlas-citation": "workspace:*",
    "effect": "^3.21.2",
    "lodash": "^4.18.1",
    "picocolors": "^1.1.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
