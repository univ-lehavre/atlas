{
  "name": "@univ-lehavre/atlas-biblio-cli",
  "version": "1.0.3",
  "description": "CLI entry point for OpenAlex bibliographic data validation",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "cli/biblio"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "atlas-biblio": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@effect/cluster": "^0.58.2",
    "@effect/experimental": "^0.60.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@univ-lehavre/atlas-openalex-types": "workspace:*",
    "@univ-lehavre/atlas-validate-openalex": "workspace:*",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
