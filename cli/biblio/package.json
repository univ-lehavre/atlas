{
  "name": "@univ-lehavre/atlas-biblio-cli",
  "version": "1.0.6",
  "description": "CLI entry point for OpenAlex bibliographic data validation",
  "author": "Pierre-Olivier Chasset",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/univ-lehavre/atlas.git",
    "directory": "cli/biblio"
  },
  "bugs": {
    "url": "https://github.com/univ-lehavre/atlas/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "atlas-biblio": "./dist/bin/atlas-biblio.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/atlas-biblio.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "~1.5.1",
    "@effect/experimental": "~0.60.0",
    "@univ-lehavre/atlas-citation-types": "workspace:*",
    "@univ-lehavre/atlas-citation-validate": "workspace:*",
    "@univ-lehavre/atlas-cli-toolkit": "workspace:*",
    "effect": "~3.21.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
