# Sillage environment variables.
#
# Copy this file to `.env.local` and fill in. In phase 7 the
# sillage-sandbox bootstrap script will write `.env.local` for you ;
# until then this file is the canonical source for what's required.

# --- Appwrite (BaaS) ---
PUBLIC_APPWRITE_ENDPOINT=http://localhost:8090/v1
PUBLIC_APPWRITE_PROJECT=sillage
APPWRITE_KEY=__set_to_your_server_api_key__

# --- Auth ---
# Where the magic-link points to in the email body.
PUBLIC_LOGIN_URL=http://localhost:5173/login
# Regex listing the email domains allowed to sign up. Default below
# covers the ULHN test domains and the sandbox-local fallback.
ALLOWED_DOMAINS_REGEXP=@(example\.org|univ-lehavre\.fr|sillage\.local)
