{
  "name": "@univ-lehavre/atlas-find-an-expert",
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "typecheck": "tsc --noEmit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "cpd": "jscpd src"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/swagger-ui-dist": "^3.30.6",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "jscpd": "^4.0.9",
    "jsdom": "^29.1.0",
    "knip": "^6.8.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@iconify/svelte": "^5.2.1",
    "@univ-lehavre/atlas-appwrite": "workspace:*",
    "@univ-lehavre/atlas-errors": "workspace:*",
    "@univ-lehavre/atlas-fetch-openalex": "workspace:*",
    "@univ-lehavre/atlas-logos": "workspace:*",
    "@univ-lehavre/atlas-validators": "workspace:*",
    "effect": "^3.21.2",
    "node-appwrite": "^24.0.0",
    "simple-git": "^3.36.0",
    "swagger-ui-dist": "^5.32.5",
    "zod": "^4.3.6"
  }
}
