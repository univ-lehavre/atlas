{
  "name": "@univ-lehavre/atlas-find-an-expert",
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && atlas-logos-install static/logos",
    "typecheck": "tsc --noEmit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "cpd": "jscpd src"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/swagger-ui-dist": "^3.30.6",
    "@univ-lehavre/atlas-logos-cli": "workspace:*",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "jscpd": "^4.0.9",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@iconify/svelte": "^5.2.1",
    "@univ-lehavre/atlas-auth": "workspace:*",
    "@univ-lehavre/atlas-baas": "workspace:*",
    "@univ-lehavre/atlas-errors": "workspace:*",
    "@univ-lehavre/atlas-citation-fetch": "workspace:*",
    "@univ-lehavre/atlas-validators": "workspace:*",
    "effect": "^3.21.2",
    "node-appwrite": "^25.2.0",
    "simple-git": "^3.36.0",
    "swagger-ui-dist": "^5.32.6",
    "zod": "^4.4.3"
  },
  "private": true
}
