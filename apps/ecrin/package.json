{
  "name": "@univ-lehavre/atlas-ecrin",
  "version": "3.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && atlas-logos-install static/logos",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "svelte-kit sync && tsc --noEmit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "svelte-kit sync && eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "svelte-kit sync && vitest run",
    "test:coverage": "svelte-kit sync && vitest run --coverage"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "@univ-lehavre/atlas-logos-cli": "workspace:*",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "@univ-lehavre/atlas-test-utils-sveltekit": "workspace:*",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.15",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@sigma/node-border": "^3.0.0",
    "@sigma/node-image": "^3.0.0",
    "@univ-lehavre/atlas-auth": "workspace:*",
    "@univ-lehavre/atlas-baas": "workspace:*",
    "@univ-lehavre/atlas-errors": "workspace:*",
    "@univ-lehavre/atlas-sveltekit-csp": "workspace:*",
    "@univ-lehavre/atlas-sveltekit-handler": "workspace:*",
    "@univ-lehavre/atlas-validators": "workspace:*",
    "appwrite": "^25.2.0",
    "graphology": "^0.26.0",
    "graphology-layout": "^0.6.1",
    "graphology-layout-force": "^0.2.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "node-appwrite": "^25.2.0",
    "openapi-response-validator": "^12.1.3",
    "sigma": "^3.0.3",
    "uuid": "^14.0.0"
  },
  "private": true
}
