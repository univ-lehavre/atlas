{
  "name": "@univ-lehavre/atlas-crf-dashboard",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "svelte-kit sync && tsc --noEmit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "svelte-kit sync && eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "svelte-kit sync && vitest run --passWithNoTests",
    "test:coverage": "svelte-kit sync && vitest run --coverage --passWithNoTests"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^25.9.3",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "@sentry/sveltekit": "~10.65.0",
    "@univ-lehavre/atlas-crf-logs": "workspace:*",
    "@univ-lehavre/atlas-sveltekit-csp": "workspace:*"
  },
  "engines": {
    "node": "^24.0.0"
  }
}
