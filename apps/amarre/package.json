{
  "name": "@univ-lehavre/atlas-amarre",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "knip": "knip"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.2.0",
    "knip": "^6.3.1",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-static-copy": "^4.0.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@univ-lehavre/atlas-appwrite": "workspace:*",
    "@univ-lehavre/atlas-errors": "workspace:*",
    "@univ-lehavre/atlas-logos": "workspace:*",
    "@univ-lehavre/atlas-validators": "workspace:*",
    "luxon": "^3.7.2",
    "node-appwrite": "^23.1.0",
    "zod": "^4.3.6"
  }
}
