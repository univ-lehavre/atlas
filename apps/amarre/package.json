{
  "name": "@univ-lehavre/atlas-amarre",
  "version": "3.0.4",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && atlas-logos-install static/logos",
    "format": "prettier --write --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.prettierignore .",
    "typecheck": "tsc --noEmit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:ui": "vitest run --project ui",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "knip": "knip"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.6",
    "@types/node": "^25.9.0",
    "@univ-lehavre/atlas-shared-config": "workspace:*",
    "eslint": "^10.4.0",
    "happy-dom": "^20.8.8",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.55.8",
    "svelte-check": "^4.4.8",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@univ-lehavre/atlas-auth": "workspace:*",
    "@univ-lehavre/atlas-baas": "workspace:*",
    "@univ-lehavre/atlas-errors": "workspace:*",
    "@univ-lehavre/atlas-logos": "workspace:*",
    "@univ-lehavre/atlas-ui": "workspace:*",
    "@univ-lehavre/atlas-validators": "workspace:*",
    "node-appwrite": "^25.0.0",
    "zod": "^4.4.3"
  },
  "private": true
}
